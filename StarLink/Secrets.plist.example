<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- LiveKit WebSocket server URL (e.g. wss://your-project.livekit.cloud) -->
	<key>LIVEKIT_URL</key>
	<string>wss://your-livekit-url.livekit.cloud</string>
	
	<!-- Developer Static Token. Optional if using TOKEN_SERVER_URL -->
	<key>LIVEKIT_TOKEN</key>
	<string>your-static-jwt-token-here</string>
	
	<!-- Optional Token Server API URL for dynamic token generation (e.g. https://your-domain.com/api/token) -->
	<key>TOKEN_SERVER_URL</key>
	<string></string>
</dict>
</plist>
